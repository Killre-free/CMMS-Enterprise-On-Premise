# Copy to .env and fill in real values before running the app.

DATABASE_URL=postgresql://cmms:cmms_password@localhost:5432/cmms_dev
NEXTAUTH_SECRET=change-this-to-a-random-32-character-string-minimum
NEXTAUTH_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=CMMS Pro
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Only used by docker-compose.yml to configure the postgres container and
# build the app's DATABASE_URL — irrelevant if you're not using Docker.
POSTGRES_USER=cmms
POSTGRES_PASSWORD=cmms_password
POSTGRES_DB=cmms_dev

STORAGE_TYPE=local
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

LINE_NOTIFY_TOKEN=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Web Push (browser/OS notifications, no external account needed).
# Generate a pair with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

MQTT_BROKER_URL=
MQTT_USERNAME=
MQTT_PASSWORD=

REDIS_URL=
CORS_ALLOWED_ORIGINS=http://localhost:3000

JWT_ACCESS_TOKEN_EXPIRY=15m
JWT_REFRESH_TOKEN_EXPIRY=7d
SESSION_TIMEOUT_HOURS=8

MAX_UPLOAD_SIZE_IMAGE=10485760
MAX_UPLOAD_SIZE_VIDEO=209715200
MAX_UPLOAD_SIZE_DOCUMENT=26214400
CLAMAV_HOST=

PURCHASING_API_URL=
ERP_API_URL=
HR_API_URL=
MES_API_URL=
BUDGET_API_URL=

SENTRY_DSN=

APP_VERSION=1.0.0
DATA_RETENTION_AUDIT_LOG_MONTHS=24
DATA_RETENTION_TELEMETRY_MONTHS=12
